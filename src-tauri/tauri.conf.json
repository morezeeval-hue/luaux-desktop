{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LuauX",
  "version": "1.3.0",
  "identifier": "space.prestigex.luaux.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LuauX",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCRkUzMTQ3QzhCNDM3OEQKUldTTk43VElSekgrR3h2cUF6bXp2Z2d0K3RWblQ5SkppWXZtazJUdTJTU0RVcXd6M0RsV2tpOWwK",
      "endpoints": [
        "https://github.com/morezeeval-hue/luaux-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
